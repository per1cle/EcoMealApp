@page "/shop"
@using EcoMeal.Shared.DTOs.BusinessDTOs
@using EcoMeal.Shared.DTOs.PackageDTOs
@using EcoMeal.Shared.DTOs.OrderDTOs
@using EcoMeal.Shared.DTOs.OrderPackageDTOs
@inject HttpClient Http
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Shop</PageTitle>

<div class="container mt-4">
    <h1 class="mb-4">Discover Local Vendors</h1>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-success" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!businesses.Any())
    {
        <div class="alert alert-info">No vendors found at the moment.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var b in businesses)
            {
                <div class="col">
                    <Card Class="h-100 shadow-sm border-0">
                        <img src="@b.ImageUrl" alt="@b.Name" class="card-img-top" style="height: 200px; object-fit: cover;" />

                        <CardBody Class="d-flex flex-column">
                            <div class="mb-2">
                                <CardTitle Class="mb-1 fw-bold fs-5">@b.Name</CardTitle>
                            </div>

                            <CardText Class="text-muted small mb-3">
                                @b.Description
                            </CardText>

                            <div class="mt-auto pt-3 border-top">
                                <div class="d-flex align-items-center mb-3 text-secondary" style="font-size: 0.875rem;">
                                    <i class="bi bi-geo-alt-fill text-danger me-2"></i>
                                    <span class="text-truncate" title="@b.Address">@b.Address</span>
                                </div>

                                <button class="btn btn-outline-success w-100 fw-bold shadow-sm"
                                        @onclick="() => OpenPackagesPopup(b)">
                                    <i class="bi bi-shop me-2"></i> View Packages
                                </button>
                            </div>
                        </CardBody>
                    </Card>
                </div>
            }
        </div>
    }
</div>

@if (isPopupVisible)
{
    <div class="offcanvas-backdrop fade show" @onclick="ClosePopup"></div>

    <div class="offcanvas offcanvas-bottom show d-block shadow-lg" tabindex="-1"
         style="height: 55vh; border-top-left-radius: 20px; border-top-right-radius: 20px;">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title fw-bold">Pachete - @selectedBusiness?.Name</h5>
            <button type="button" class="btn-close" @onclick="ClosePopup" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            @if (isLoadingPackages)
            {
                <div class="d-flex justify-content-center my-4">
                    <div class="spinner-border text-success" role="status"></div>
                </div>
            }
            else if (!packages.Any())
            {
                <div class="alert alert-warning">No packages available for this business at the moment.</div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var package in packages)
                    {
                        <div
                            class="list-group-item d-flex justify-content-between align-items-center mb-2 shadow-sm border rounded">
                            <div class="me-3">
                                <h6 class="mb-1 fw-bold">@package.Name</h6>
                                <small class="text-muted d-block mb-1">@package.Description</small>
                                <span class="badge bg-success fs-6">@package.Price RON</span>
                            </div>
                            @{
                                var cartItem = cart.FirstOrDefault(c => c.Package.Id == package.Id);
                            }
                            @if (cartItem == null)
                            {
                                <button class="btn btn-success fw-bold px-4" @onclick="() => AddToCart(package)">
                                    Add
                                </button>
                            }
                            else
                            {
                                <div class="d-flex align-items-center gap-2">
                                    <button
                                        class="btn btn-outline-success btn-sm rounded-circle d-flex align-items-center justify-content-center"
                                        style="width: 32px; height: 32px;" @onclick="() => UpdateQuantity(cartItem, -1)">
                                        <i class="bi bi-dash-lg"></i>
                                    </button>
                                    <span class="fw-bold" style="min-width: 20px; text-align: center;">@cartItem.Quantity</span>
                                    <button
                                        class="btn btn-outline-success btn-sm rounded-circle d-flex align-items-center justify-content-center"
                                        style="width: 32px; height: 32px;" @onclick="() => UpdateQuantity(cartItem, 1)">
                                        <i class="bi bi-plus-lg"></i>
                                    </button>
                                </div>
                            }
                        </div>
                    }
                </div>
                @if (cart.Any())
                {
                    <div class="card bg-light border-0 shadow-sm mt-auto">
                        <div class="card-body">
                            <h6 class="fw-bold">În comandă: @cart.Sum(c => c.Quantity) pachete</h6>
                            <button class="btn btn-success w-100 fw-bold mt-2" @onclick="SubmitOrder">
                                Place Order
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
}

@if (showSuccessMessage)
{
    <div class="position-fixed top-0 start-50 translate-middle-x mt-4" style="z-index: 1080;">
        <div class="alert alert-success shadow-lg d-flex align-items-center px-4 py-3 mb-0 rounded-3" role="alert">
            <i class="bi bi-check-circle-fill fs-4 me-2"></i>
            <span class="fw-bold">Comanda a fost plasată cu succes!</span>
        </div>
    </div>
}

@code {
    private List<BusinessGetDTO> businesses = new List<BusinessGetDTO>();
    private bool isLoading = true;
    private Guid currentUserId;
    private bool showSuccessMessage = false;

    private bool isPopupVisible = false;
    private BusinessGetDTO? selectedBusiness;
    private List<PackageGetDTO> packages = new();
    private bool isLoadingPackages = false;

    public class CartItem
    {
        public PackageGetDTO Package { get; set; } = new();
        public int Quantity { get; set; }
    }

    List<CartItem> cart = new List<CartItem>();

    private void AddToCart(PackageGetDTO package)
    {
        var existingItem = cart.FirstOrDefault(c => c.Package.Id == package.Id);
        if (existingItem != null)
        {
            existingItem.Quantity++;
        }
        else
        {
            cart.Add(new CartItem { Package = package, Quantity = 1 });
        }
    }

    private void UpdateQuantity(CartItem item, int delta)
    {
        item.Quantity += delta;
        if (item.Quantity <= 0) cart.Remove(item);
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUserId = user.Identity?.IsAuthenticated == true ? Guid.Parse(user.FindFirst("sub")?.Value ??
Guid.Empty.ToString()) : Guid.Empty;

        isLoading = true;
        try
        {
            businesses = await Http.GetFromJsonAsync<List<BusinessGetDTO>>("api/businesses") ?? new List<BusinessGetDTO>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Loading Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OpenPackagesPopup(BusinessGetDTO business)
    {
        selectedBusiness = business;
        isPopupVisible = true;
        isLoadingPackages = true;

        try
        {
            packages = await Http.GetFromJsonAsync<List<PackageGetDTO>>($"api/packages") ?? new();
            packages = packages.Where(p => p.BusinessId == business.Id).ToList();

        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading packages: {ex.Message}");
        }
        finally
        {
            isLoadingPackages = false;
        }
    }

    private void ClosePopup()
    {
        isPopupVisible = false;
        selectedBusiness = null;
        packages.Clear();
    }

    private async Task SubmitOrder()
    {
        if (cart.Any() && selectedBusiness != null)
        {
            var orderDto = new OrderCreateDTO
            {
                UserId = currentUserId,
                BusinessId = selectedBusiness.Id,
                OrderNumber = new Random().Next(1000, 9999),
                OrderPackages = cart.Select(item => new OrderPackageCreateDTO
                {
                    PackageId = item.Package.Id,
                    Quantity = item.Quantity
                }).ToList()
            };

            var response = await Http.PostAsJsonAsync("api/orders", orderDto);

            if (response.IsSuccessStatusCode)
            {
                cart.Clear();
                isPopupVisible = false;
                showSuccessMessage = true;
                StateHasChanged();

                await Task.Delay(5000);
                showSuccessMessage = false;
                StateHasChanged();
            }
            else
            {
                Console.WriteLine("Eroare la plasarea comenzii");
            }
        }
    }

}