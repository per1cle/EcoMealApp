@page "/shop"
@using EcoMeal.Shared.DTOs.BusinessDTOs
@using EcoMeal.Shared.DTOs.PackageDTOs
@using EcoMeal.Shared.DTOs.OrderDTOs
@using EcoMeal.Shared.DTOs.OrderPackageDTOs
@inject HttpClient Http
@inject AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>Shop</PageTitle>

<div class="container mt-4">
    <h1 class="mb-4">Discover Local Vendors</h1>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-success" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else if (!businesses.Any())
    {
        <div class="alert alert-info">No vendors found at the moment.</div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var b in businesses)
            {
                <div class="col">
                    <Card Class="h-100 shadow-sm border-0">
                        <img src="@b.ImageUrl" alt="@b.Name" class="card-img-top" style="height: 200px; object-fit: cover;" />

                        <CardBody Class="d-flex flex-column">
                            <div class="mb-2">
                                <CardTitle Class="mb-1 fw-bold fs-5">@b.Name</CardTitle>
                            </div>

                            <CardText Class="text-muted small mb-3">
                                @b.Description
                            </CardText>

                            <div class="mt-auto pt-3 border-top">
                                <div class="d-flex align-items-center mb-3 text-secondary" style="font-size: 0.875rem;">
                                    <i class="bi bi-geo-alt-fill text-danger me-2"></i>
                                    <span class="text-truncate" title="@b.Address">@b.Address</span>
                                </div>

                                <button class="btn btn-outline-success w-100 fw-bold shadow-sm"
                                        @onclick="() => OpenPackagesPopup(b)">
                                    <i class="bi bi-shop me-2"></i> View Packages
                                </button>
                            </div>
                        </CardBody>
                    </Card>
                </div>
            }
        </div>
    }
</div>

@if (isPopupVisible)
{
    <div class="offcanvas-backdrop fade show" @onclick="ClosePopup"></div>

    <div class="offcanvas offcanvas-bottom show d-block shadow-lg" tabindex="-1"
         style="height: 75vh; border-top-left-radius: 20px; border-top-right-radius: 20px;">
        <div class="offcanvas-header border-bottom">
            <h5 class="offcanvas-title fw-bold">Packages - @selectedBusiness?.Name</h5>
            <button type="button" class="btn-close" @onclick="ClosePopup" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            @if (isLoadingPackages)
            {
                <div class="d-flex justify-content-center my-4">
                    <div class="spinner-border text-success" role="status"></div>
                </div>
            }
            else if (!packages.Any())
            {
                <div class="alert alert-warning">No packages available for this business at the moment.</div>
            }
            else
            {
                <div class="list-group">
                    @foreach (var package in packages)
                    {
                        <div
                            class="list-group-item d-flex justify-content-between align-items-center mb-2 shadow-sm border rounded p-3 bg-white">

                            <div class="d-flex align-items-center" style="flex: 1; min-width: 0;">
                                <img src="@(string.IsNullOrEmpty(package.ImageUrl) ? "images/default-package.png" : package.ImageUrl)"
                                     alt="@package.Name" class="me-3 border shadow-sm"
                                     style="width: 80px; height: 80px; object-fit: cover; border-radius: 8px;" />

                                <div class="text-truncate" style="max-width: calc(100% - 100px);">
                                    <h6 class="mb-1 fw-bold text-dark text-truncate">@package.Name</h6>
                                    <small class="text-muted d-block text-truncate" style="max-width: 260px;"
                                           title="@package.Description">
                                        @package.Description
                                    </small>
                                </div>
                            </div>

                            <div class="text-center px-4" style="flex: 1; min-width: 150px;">
                                <span class="text-muted small d-block mb-1">
                                    <i class="bi bi-clock me-1"></i>Pickup Window:
                                </span>
                                <strong class="text-dark">
                                    @package.PickupStart.ToString("HH:mm") - @package.PickupEnd.ToString("HH:mm")
                                </strong>
                            </div>

                            @{
                                var cartItem = cart.FirstOrDefault(c => c.Package.Id == package.Id);
                            }
                            <div class="d-flex align-items-center gap-3 justify-content-end" style="flex: 1; min-width: 220px;">

                                <div class="text-end me-2">
                                    <span class="fw-bold text-success fs-5 d-block">@package.Price RON</span>
                                    <small class="text-muted d-block" style="font-size: 0.8rem;">
                                        Stock: @package.Quantity packages
                                    </small>
                                </div>

                                
                                <div style="min-width: 100px; display: flex; justify-content: flex-end;">
                                    @if (cartItem == null)
                                    {
                                        <button class="btn btn-success fw-bold px-4" @onclick="() => AddToCart(package)"
                                                disabled="@(package.Quantity <= 0)">
                                            @(package.Quantity <= 0 ? "Epuizat" : "Add")
                                        </button>
                                    }
                                    else
                                    {
                                        <div class="d-flex align-items-center gap-2">

                                            <button
                                                class="btn btn-outline-success btn-sm rounded-circle d-flex align-items-center justify-content-center"
                                                style="width: 32px; height: 32px; cursor: pointer;"
                                                @onclick="() => UpdateQuantity(cartItem, -1)">
                                                <i class="bi bi-chevron-down"></i>
                                            </button>

                                            <span class="fw-bold" style="min-width: 20px; text-align: center;">@cartItem.Quantity</span>

                                            
                                            <button
                                                class="btn btn-outline-success btn-sm rounded-circle d-flex align-items-center justify-content-center"
                                                style="width: 32px; height: 32px; cursor: pointer;"
                                                @onclick="() => UpdateQuantity(cartItem, 1)"
                                                disabled="@(cartItem.Quantity >= package.Quantity)">
                                                <i class="bi bi-chevron-up"></i>
                                            </button>
                                        </div>
                                    }
                                </div>
                            </div>

                        </div>
                    }
                </div>
                @if (cart.Any())
                {
                    <div class="card bg-light border-0 shadow-sm mt-auto">
                        <div class="card-body">
                            <h6 class="fw-bold">My Order:</h6>
                            <ul class="list-group list-group-flush mb-3">
                                @foreach (var item in cart)
                                {
                                    <li class="list-group-item d-flex justify-content-between align-items-center">
                                        <span>@item.Package.Name (@item.Quantity)</span>
                                        <span class="fw-bold">@((item.Package.Price * item.Quantity)) RON</span>
                                    </li>
                                }
                            </ul>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <span class="fw-bold">Total:</span>
                                <span class="fw-bold">@((cart.Sum(item => item.Package.Price * item.Quantity))) RON</span>
                            </div>
                            <button class="btn btn-success w-100 fw-bold mt-2" @onclick="SubmitOrder">
                                Place Order
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
}

@if (showSuccessPopup)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0, 0, 0, 0.5); z-index: 1080;">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow-lg border-0" style="border-radius: 16px;">

                <div class="modal-header bg-success text-white py-3" style="border-top-left-radius: 16px; border-top-right-    
                    radius: 16px;">
                    <h5 class="modal-title fw-bold m-0">
                        <i class="bi bi-check-circle-fill me-2"></i>Order Submitted!
                    </h5>
                    <button type="button" class="btn-close btn-close-white" @onclick="() => showSuccessPopup = false" aria-
                            label="Close"></button>
                </div>

                <div class="modal-body p-4">
                    <div class="text-center mb-4">
                        <div class="display-3 text-success mb-2">
                            <i class="bi bi-bag-check-fill"></i>
                        </div>
                        <h4 class="fw-bold text-dark">Order #@lastOrderNumber</h4>
                        <span class="badge bg-success-subtle text-success px-3 py-2 rounded-pill fw-semibold">Placed
                            successfully!</span>
                        </div>

                        <div class="mb-4 bg-light p-3 rounded-3 border">
                            <h6 class="fw-bold text-secondary text-uppercase mb-2" style="font-size: 0.75rem; letter-spacing: 0.   
                            05em;">Vendor: </h6>
                            <h5 class="fw-bold text-dark mb-1">@lastBusinessName</h5>
                            <p class="text-muted small mb-0">
                                <i class="bi bi-geo-alt-fill text-danger me-1"></i>@lastBusinessAddress
                            </p>
                        </div>

                        <div class="mb-4">
                            <h6 class="fw-bold text-secondary text-uppercase mb-2" style="font-size: 0.75rem; letter-spacing: 0.   
                            05em;">Items: </h6>
                            <div style="max-height: 180px; overflow-y: auto;">
                                <ul class="list-group list-group-flush">
                                    @foreach (var item in lastOrderItems)
                                    {
                                        <li class="list-group-item d-flex justify-content-between align-items-center px-0 py-2     
                                            border-bottom-0">
                                            <span class="text-dark">@item.Package.Name <strong class="text-success ms-1"> x
                                                @item.Quantity</strong></span>
                                                <span class="fw-bold text-dark">@(item.Package.Price * item.Quantity) RON</span>
                                            </li>
                                        }
                                    </ul>
                                </div>
                            </div>

                            <div class="d-flex justify-content-between fw-bold fs-5 border-top pt-3 mt-2">
                                <span class="text-dark">Total:</span>
                                <span class="text-success">@lastOrderTotal RON</span>
                            </div>
                        </div>

                        <div class="modal-footer border-0 p-3 bg-light" style="border-bottom-left-radius: 16px; border-bottom-right-   
                            radius: 16px;">
                            <button type="button" class="btn btn-success w-100 fw-bold py-2"
                                    @onclick="() => showSuccessPopup = false">
                                <i class="bi bi-check-circle me-2"></i>OK
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }

@code {
    private List<BusinessGetDTO> businesses = new List<BusinessGetDTO>();
    private bool isLoading = true;
    private Guid currentUserId;

    private bool showSuccessPopup = false;
    private string? lastBusinessName;
    private string? lastBusinessAddress;
    private int lastOrderNumber;
    private List<CartItem> lastOrderItems = new();
    private double lastOrderTotal;

    private bool isPopupVisible = false;
    private BusinessGetDTO? selectedBusiness;
    private List<PackageGetDTO> packages = new();
    private bool isLoadingPackages = false;

    public class CartItem
    {
        public PackageGetDTO Package { get; set; } = new();
        public int Quantity { get; set; }
    }

    List<CartItem> cart = new List<CartItem>();

    private void AddToCart(PackageGetDTO package)
    {
        var existingItem = cart.FirstOrDefault(c => c.Package.Id == package.Id);
        if (existingItem != null)
        {
            existingItem.Quantity++;
        }
        else
        {
            cart.Add(new CartItem { Package = package, Quantity = 1 });
        }
    }

    private void UpdateQuantity(CartItem item, int delta)
    {
        item.Quantity += delta;
        if (item.Quantity <= 0) cart.Remove(item);
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
        var user = authState.User;
        currentUserId = user.Identity?.IsAuthenticated == true ? Guid.Parse(user.FindFirst(System.Security.Claims.ClaimTypes.
  NameIdentifier)?.Value ?? Guid.Empty.ToString()) : Guid.Empty;

        isLoading = true;
        try
        {
            businesses = await Http.GetFromJsonAsync<List<BusinessGetDTO>>("api/businesses") ?? new List<BusinessGetDTO>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Loading Error: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task OpenPackagesPopup(BusinessGetDTO business)
    {
        selectedBusiness = business;
        isPopupVisible = true;
        isLoadingPackages = true;

        try
        {
            packages = await Http.GetFromJsonAsync<List<PackageGetDTO>>($"api/packages") ?? new();
            packages = packages.Where(p => p.BusinessId == business.Id).ToList();

        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading packages: {ex.Message}");
        }
        finally
        {
            isLoadingPackages = false;
        }
    }

    private void ClosePopup()
    {
        isPopupVisible = false;
        selectedBusiness = null;
        packages.Clear();
    }

    private async Task SubmitOrder()
    {
        if (cart.Any() && selectedBusiness != null)
        {
            var orderDto = new OrderCreateDTO
            {
                UserId = currentUserId,
                BusinessId = selectedBusiness.Id,
                OrderNumber = new Random().Next(1000, 9999),
                OrderPackages = cart.Select(item => new OrderPackageCreateDTO
                {
                    PackageId = item.Package.Id,
                    Quantity = item.Quantity
                }).ToList()
            };

            var response = await Http.PostAsJsonAsync("api/orders", orderDto);

            if (response.IsSuccessStatusCode)
            {
                lastBusinessName = selectedBusiness.Name;
                lastBusinessAddress = selectedBusiness.Address;
                lastOrderNumber = orderDto.OrderNumber;
                lastOrderItems = new List<CartItem>(cart);
                lastOrderTotal = cart.Sum(item => item.Quantity * (int)item.Package.Price);

                cart.Clear();
                isPopupVisible = false;
                showSuccessPopup = true;
                StateHasChanged();

            }
            else
            {
                Console.WriteLine("Eroare la plasarea comenzii");
            }
        }
    }

    private async Task<int> Total()
    {
        return cart.Sum(item => item.Quantity * (int)item.Package.Price);
    }

}