@page "/register-business"
@using EcoMeal.Shared.DTOs.AuthDTOs
@using EcoMeal.UI.Services
@inject IAuthService AuthService
@inject NavigationManager NavigationManager

<PageTitle>Business Partner - EcoMeal</PageTitle>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm border-0 rounded-3 border-top border-warning border-4">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <div class="bg-warning bg-opacity-10 text-warning rounded-circle d-inline-block p-3 mb-3">
                            <i class="bi bi-shop" style="font-size: 2.5rem;"></i>
                        </div>
                        <h2 class="fw-bold">Become a Partner</h2>
                        <p class="text-muted">Sell your surplus food and reduce waste.</p>
                    </div>

                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="alert alert-danger" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> @errorMessage
                        </div>
                    }

                    <EditForm Model="registerModel" OnValidSubmit="HandleRegister">
                        <DataAnnotationsValidator />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Manager Full Name</label>
                            <InputText @bind-Value="registerModel.Name" class="form-control" placeholder="John Doe" />
                            <ValidationMessage For="@(() => registerModel.Name)" class="text-danger small mt-1" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Business Email Address</label>
                            <InputText @bind-Value="registerModel.Email" class="form-control"
                                       placeholder="contact@myrestaurant.com" />
                            <ValidationMessage For="@(() => registerModel.Email)" class="text-danger small mt-1" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Password</label>
                            <InputText @bind-Value="registerModel.Password" type="password" class="form-control"
                                       placeholder="••••••••" />
                            <ValidationMessage For="@(() => registerModel.Password)" class="text-danger small mt-1" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Confirm Password</label>
                            <InputText @bind-Value="registerModel.ConfirmPassword" type="password" class="form-control"
                                       placeholder="••••••••" />
                            <ValidationMessage For="@(() => registerModel.ConfirmPassword)"
                                               class="text-danger small mt-1" />
                        </div>

                        <button type="submit" class="btn btn-warning btn-lg w-100 fw-bold text-dark"
                                disabled="@isLoading">
                            @if (isLoading)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Applying...</span>
                            }
                            else
                            {
                                <span>Create Business Account</span>
                            }
                        </button>
                    </EditForm>

                    <div class="text-center mt-3">
                        <a href="/register" class="text-muted text-decoration-none small"><i
                            class="bi bi-arrow-left"></i> Back to normal Sign Up</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

@code {
    private RegisterDTO registerModel = new RegisterDTO();
    private bool isLoading = false;
    private string? errorMessage;

    private async Task HandleRegister()
    {
        isLoading = true;
        errorMessage = null;

        // Aici apelăm metoda specială pentru business!
        var result = await AuthService.RegisterBusiness(registerModel);

        if (result.IsSuccess)
        {
            NavigationManager.NavigateTo("/login");
        }
        else
        {
            errorMessage = result.ErrorMessage;
            isLoading = false;
        }
    }
}