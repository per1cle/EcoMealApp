@using EcoMeal.UI.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject IAuthService AuthService
@inject NavigationManager NavManager

<AuthorizeView>
    <Authorized>
        <div class="d-flex align-items-center">
            <span class="me-3 fw-bold text-success">
                <i class="bi bi-person-circle me-1"></i> Hello, @context.User.Identity?.Name!
            </span>
            <button class="btn btn-outline-danger btn-sm fw-bold shadow-sm" @onclick="HandleLogout">
                <i class="bi bi-box-arrow-right me-1"></i> Logout
            </button>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="d-flex gap-2">
            <a href="/login" class="btn btn-outline-success fw-bold shadow-sm">Log In</a>
            <a href="/register" class="btn btn-success fw-bold shadow-sm">Sign Up</a>
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private async Task HandleLogout()
    {
        await AuthService.Logout();
        NavManager.NavigateTo("/");
    }
}