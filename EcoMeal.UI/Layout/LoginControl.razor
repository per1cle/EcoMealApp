@using EcoMeal.UI.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject IAuthService AuthService
@inject NavigationManager NavManager

<AuthorizeView>
    <Authorized>
        <div class="d-flex align-items-center">
            <AuthorizeView Roles="Customer" Context="customerContext">
                <a href="/my-orders" class="me-3 text-dark text-decoration-none fw-semibold" style="font-size: 0.9rem;" title="My Orders">
                    <i class="bi bi-bag-fill me-1 text-success"></i> My Orders
                </a>
            </AuthorizeView>

            <span class="badge bg-white text-dark border border-success-subtle me-3 px-3 py-2 fw-semibold shadow-sm" style="font-size: 0.9rem; border-radius: 8px;">
                <i class="bi bi-person-circle me-1 text-success"></i> Hello, @context.User.Identity?.Name!
            </span>
            <button class="btn btn-outline-danger btn-sm fw-bold shadow-sm" @onclick="HandleLogout">
                <i class="bi bi-box-arrow-right me-1"></i> Logout
            </button>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="d-flex gap-2">
            <a href="/login" class="btn btn-outline-success fw-bold shadow-sm">Log In</a>
            <a href="/register" class="btn btn-success fw-bold shadow-sm">Sign Up</a>
        </div>
    </NotAuthorized>
</AuthorizeView>


@code {
    private async Task HandleLogout()
    {
        await AuthService.Logout();
        NavManager.NavigateTo("/");
    }
}