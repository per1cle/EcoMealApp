<CascadingAuthenticationState>
    <Router AppAssembly="@typeof(App).Assembly">
        <Found Context="routeData">
            <AuthorizeRouteView RouteData="@routeData" DefaultLayout="@typeof(MainLayout)">
                <NotAuthorized>
                    <div class="container mt-5 text-center">
                        <h2 class="text-danger fw-bold"><i class="bi bi-shield-lock-fill me-2"></i>Access Denied</h2>
                        <p class="text-muted">You need to be logged in and have the correct permissions to view this
                            page.</p>
                            <a href="/login" class="btn btn-success mt-3 px-4 fw-bold">Go to Login</a>
                        </div>
                    </NotAuthorized>
                </AuthorizeRouteView>
                <FocusOnNavigate RouteData="@routeData" Selector="h1" />
            </Found>
            <NotFound>
                <PageTitle>Not found</PageTitle>
                <LayoutView Layout="@typeof(MainLayout)">
                    <div class="container mt-5 text-center">
                        <h2>Page not found!</h2>
                        <p>Sorry, there's nothing at this address.</p>
                    </div>
                </LayoutView>
            </NotFound>
        </Router>
    </CascadingAuthenticationState>