@page "/admin/businesses"
@using EcoMeal.Shared.DTOs.BusinessDTOs
@using EcoMeal.Shared.DTOs.BusinessTypeDTOs
@using System.IO
@inject HttpClient Http

<PageTitle>Admin - Businesses</PageTitle>

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Business Management</h1>
        <button class="btn btn-primary shadow-sm" @onclick="() => ShowPopup(new BusinessGetDTO())">
            <i class="bi bi-plus-lg me-2"></i> Add New Business
        </button>
    </div>

    @if (isLoading)
    {
        <div class="d-flex justify-content-center my-5">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <table class="table table-hover table-striped mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Image</th>
                            <th>Name</th>
                            <th>Type</th>
                            <th>Address</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var b in businesses)
                        {
                            <tr>
                                <td style="width: 80px;">
                                    @if (!string.IsNullOrWhiteSpace(b.ImageUrl))
                                    {
                                        <img src="@b.ImageUrl" alt="img" class="rounded"
                                             style="width: 50px; height: 50px; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <div class="bg-secondary text-white rounded d-flex align-items-center justify-content-center"
                                             style="width: 50px; height: 50px;">
                                            <i class="bi bi-shop"></i>
                                        </div>
                                    }
                                </td>
                                <td class="align-middle fw-bold">@b.Name</td>
                                <td class="align-middle text-muted">
                                    @(businessTypes.FirstOrDefault(bt => bt.Id == b.BusinessTypeId)?.Name ?? "Unknown")
                                </td>
                                <td class="align-middle">@b.Address</td>
                                <td class="align-middle text-end">
                                    <button class="btn btn-sm btn-outline-secondary me-2" @onclick="() => ShowPopup(b)">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => DeleteBusiness(b.Id)">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </td>
                            </tr>
                        }
                        @if (!businesses.Any())
                        {
                            <tr>
                                <td colspan="5" class="text-center py-4 text-muted">No businesses found.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>

@if (isPopupVisible && editModel != null)
{
    <div class="modal fade show d-block" tabindex="-1" style="background-color: rgba(0,0,0,0.5);">
        <div class="modal-dialog modal-dialog-centered modal-lg">
            <div class="modal-content">

                <div class="modal-header">
                    <h5 class="modal-title fw-bold">@(isNew ? "Add Business" : "Edit Business")</h5>
                    <button type="button" class="btn-close" @onclick="ClosePopup"></button>
                </div>

                <EditForm Model="@editModel" OnValidSubmit="OnValidSubmit">
                    <DataAnnotationsValidator></DataAnnotationsValidator>

                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Business Name</label>
                                <InputText @bind-Value="editModel.Name" class="form-control"
                                           placeholder="e.g., Green Bite Bistro" />
                                <ValidationMessage For="@(() => editModel.Name)" />
                            </div>

                            <div class="col-md-6 mb-3">
                                <label class="form-label fw-bold">Business Type</label>
                                <InputSelect @bind-Value="editModel.BusinessTypeId" class="form-select">
                                    <option value="@Guid.Empty">-- Select type --</option>
                                    @foreach (var bt in businessTypes)
                                    {
                                        <option value="@bt.Id">@bt.Name</option>
                                    }
                                </InputSelect>
                                <ValidationMessage For="@(() => editModel.BusinessTypeId)" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Address</label>
                            <InputText @bind-Value="editModel.Address" class="form-control"
                                       placeholder="Street name and number..." />
                            <ValidationMessage For="@(() => editModel.Address)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Description</label>
                            <InputTextArea @bind-Value="editModel.Description" class="form-control" rows="3"
                                           placeholder="Optional description..." />
                            <ValidationMessage For="@(() => editModel.Description)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Image (Upload file or paste URL)</label>

                            @if (!string.IsNullOrWhiteSpace(editModel.ImageUrl))
                            {
                                <div class="mb-2 text-center">
                                    <img src="@editModel.ImageUrl" alt="Preview" class="img-thumbnail shadow-sm"
                                         style="max-height: 160px; object-fit: cover;" />
                                </div>
                            }

                            <div class="input-group mb-2">
                                <span class="input-group-text"><i class="bi bi-link-45deg"></i></span>
                                <InputText @bind-Value="editModel.ImageUrl" class="form-control"
                                           placeholder="Paste image URL here (https://)..." />
                            </div>

                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-upload"></i></span>
                                <InputFile OnChange="LoadFiles" class="form-control"
                                           accept="image/png, image/jpeg, image/webp" />
                            </div>

                            <ValidationMessage For="@(() => editModel.ImageUrl)" />
                            <small class="text-muted">You can either paste a direct link or upload an image from your device
                                (Max 5MB).</small>
                            </div>
                        </div>

                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" @onclick="ClosePopup">Cancel</button>
                            <button type="submit" class="btn btn-success fw-bold" disabled="@isSaving">
                                @if (isSaving)
                                {
                                    <span class="spinner-border spinner-border-sm me-1" role="status" aria-hidden="true"></span>
                                    <span>Saving...</span>
                                }
                                else
                                {
                                    <i class="bi bi-check-lg me-1"></i> <span>Save</span>
                                }
                            </button>
                        </div>

                    </EditForm>
                </div>
            </div>
        </div>
    }

@code {
    private List<BusinessGetDTO> businesses = new List<BusinessGetDTO>();
    private List<BusinessTypeGetDTO> businessTypes = new List<BusinessTypeGetDTO>();

    private BusinessUpdateDTO? editModel;

    private bool isPopupVisible = false;
    private bool isLoading = true;
    private bool isSaving = false;

    private bool isNew => editModel?.Id == Guid.Empty;

    private long maxFileSize = 1024 * 1024 * 5;

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        isLoading = true;
        try
        {
            businessTypes = await Http.GetFromJsonAsync<List<BusinessTypeGetDTO>>("api/businesstypes") ?? new
List<BusinessTypeGetDTO>();
            businesses = await Http.GetFromJsonAsync<List<BusinessGetDTO>>("api/businesses") ?? new List<BusinessGetDTO>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading data: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void ShowPopup(BusinessGetDTO b)
    {
        editModel = new BusinessUpdateDTO
        {
            Id = b.Id,
            Name = b.Name,
            Address = b.Address,
            Description = b.Description,
            ImageUrl = b.ImageUrl,
            BusinessTypeId = b.BusinessTypeId
        };

        isPopupVisible = true;
    }

    private void ClosePopup()
    {
        isPopupVisible = false;
        editModel = null;
    }

    private async Task LoadFiles(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file != null)
        {
            try
            {
                using var stream = file.OpenReadStream(maxFileSize);
                using var memoryStream = new MemoryStream();
                await stream.CopyToAsync(memoryStream);
                var imageBytes = memoryStream.ToArray();

                var base64String = Convert.ToBase64String(imageBytes);
                var format = file.ContentType;

                if (editModel != null)
                {
                    editModel.ImageUrl = $"data:{format};base64,{base64String}";
                }
            }
            catch (Exception ex)
            {
                Console.WriteLine($"Error uploading file: {ex.Message}");
            }
        }
    }

    private async Task OnValidSubmit()
    {
        if (editModel == null || editModel.BusinessTypeId == Guid.Empty) return;

        editModel.Name = editModel.Name?.Trim() ?? string.Empty;
        editModel.Address = editModel.Address?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(editModel.Description))
            editModel.Description = null;
        else
            editModel.Description = editModel.Description.Trim();

        if (string.IsNullOrWhiteSpace(editModel.ImageUrl))
            editModel.ImageUrl = null;
        else
            editModel.ImageUrl = editModel.ImageUrl.Trim();

        isSaving = true;
        try
        {
            if (isNew)
            {
                var createDto = new BusinessCreateDTO
                {
                    Name = editModel.Name,
                    Address = editModel.Address,
                    Description = editModel.Description,
                    ImageUrl = editModel.ImageUrl,
                    BusinessTypeId = editModel.BusinessTypeId
                };

                await Http.PostAsJsonAsync("api/businesses", createDto);
            }
            else
            {
                await Http.PutAsJsonAsync($"api/businesses/{editModel.Id}", editModel);
            }

            await LoadDataAsync();
            ClosePopup();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving data: {ex.Message}");
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task DeleteBusiness(Guid id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/businesses/{id}");
            if (response.IsSuccessStatusCode)
            {
                await LoadDataAsync();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting data: {ex.Message}");
        }
    }
}